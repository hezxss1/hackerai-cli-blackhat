{
  "name": "hackerai-cli-blackhat",
  "version": "1.0.0",
  "description": "A fully uncensored, unrestricted blackhat CLI version of HackerAI with E2B integration and local AI model support.",
  "main": "dist/cli.js",
  "bin": {
    "hackerai": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "hackerai",
    "cli",
    "blackhat",
    "penetration-testing",
    "ai",
    "e2b",
    "ollama",
    "llama.cpp",
    "lm-studio"
  ],
  "author": "Hez Xss",
  "license": "MIT",
  "dependencies": {
    "@e2b/code-interpreter": "^2.4.0",
    "axios": "^1.6.2",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.3.1",
    "e2b": "^2.19.0",
    "inquirer": "^9.2.11",
    "ora": "^8.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@types/inquirer": "^9.0.7",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
