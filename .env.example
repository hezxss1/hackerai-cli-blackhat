# HackerAI CLI - Blackhat Edition Environment Configuration
# Copy this file to .env and fill in your values

# E2B Configuration (Required for sandboxed code execution)
E2B_API_KEY=your_e2b_api_key_here

# Local AI Model Configuration
# Ollama (Default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Llama.cpp
LLAMACPP_BASE_URL=http://localhost:8080

# LM Studio
LMSTUDIO_BASE_URL=http://localhost:1234

# Default Model (e.g., ollama:llama3.2:3b, llamacpp:model.gguf, lmstudio:model)
DEFAULT_MODEL=ollama:llama3.2:3b

# Logging Level (debug, info, warn, error)
LOG_LEVEL=info

# Agent Mode Configuration
AGENT_TIMEOUT=300000  # 5 minutes in ms
AGENT_MAX_ITERATIONS=50

# Security (Optional)
# Set to 'true' to enable strict mode (recommended for testing)
STRICT_MODE=false
